# Production Environment Variables
# Copy this file to .env.production and update values for your VPS

# Database
DB_USER=datto
DB_PASSWORD=change_me_in_production
DB_NAME=datto_rmm

# Node Environment
NODE_ENV=production

# JWT Secrets (Generate secure random strings - use `openssl rand -base64 32`)
JWT_SECRET=change_me_to_secure_random_key_min_32_chars
REFRESH_TOKEN_SECRET=change_me_to_secure_random_key_min_32_chars

# Frontend API URLs (use relative paths with nginx proxy)
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_WS_URL=

# CORS Origins (your domain)
CORS_ORIGINS=https://joininvite.org,https://www.joininvite.org

# Your VPS Configuration
VPS_DOMAIN=joininvite.org
VPS_IP=194.195.87.52

# Optional: Absolute URLs if needed
# NEXT_PUBLIC_API_URL=https://joininvite.org/api/v1
# NEXT_PUBLIC_WS_URL=https://joininvite.org
