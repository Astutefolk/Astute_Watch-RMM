# DATTO RMM - Environment Variables
# Copy this file to .env and update values for your environment

# ============ Database ============
DB_USER=datto
DB_PASSWORD=change_me_in_production
DB_NAME=datto_rmm

# ============ Node/Environment ============
NODE_ENV=production

# ============ JWT Secrets ============
# Generate secure random keys: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
REFRESH_TOKEN_SECRET=your_super_secret_refresh_key_here_change_in_production

# ============ CORS ============
CORS_ORIGINS=http://localhost:3001,http://frontend:3001

# ============ Frontend URLs ============
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:3000

# ============ Rate Limiting ============
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============ Agent Configuration ============
AGENT_HEARTBEAT_INTERVAL=30000
AGENT_OFFLINE_THRESHOLD=120000

# ============ Alert Thresholds ============
ALERT_CPU_THRESHOLD=85
ALERT_RAM_THRESHOLD=90
ALERT_DISK_THRESHOLD=95

# ============ Security ============
BCRYPT_ROUNDS=10
API_KEY_LENGTH=32
